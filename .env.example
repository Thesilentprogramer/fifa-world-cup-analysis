# Copy to .env and adjust if needed.
# Most users do NOT need Polymarket keys — public Gamma/CLOB endpoints work for read-only odds.

# Transfermarkt API (felipeall/transfermarkt-api)
TRANSFERMARKT_API_BASE=https://transfermarkt-api.fly.dev
TRANSFERMARKT_RATE_LIMIT_SEC=2.5

# Polymarket public market data (no auth required for reads)
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE=https://clob.polymarket.com
POLYMARKET_RATE_LIMIT_SEC=0.5

# Optional — only for authenticated trading / private CLOB access (NOT needed for odds features)
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# API-Football — required for live fixture sync (free tier: ~100 requests/day)
# Get a key at https://www.api-football.com/
API_FOOTBALL_KEY=your_key_here
API_FOOTBALL_BASE=https://v3.football.api-sports.io
API_FOOTBALL_WC_LEAGUE_ID=1
API_FOOTBALL_WC_SEASON=2026
